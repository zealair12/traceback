# Traceback server configuration.
# Copy this file to ".env" and fill in real values. The ".env" file is private
# and is never committed.

# Port the API listens on.
PORT=4000

# PostgreSQL connection string for the conversation database.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/traceback

# Where the frontend is served from (used to allow browser requests).
CLIENT_ORIGIN=http://localhost:5173

# --- LLM provider selection -------------------------------------------------
# Which language-model backend answers messages by default. Traceback treats
# every backend as an interchangeable plugin; this picks the default one.
# Supported: groq | openai | anthropic | local
LLM_PROVIDER=groq

# --- Provider credentials ---------------------------------------------------
# Only the key for the provider(s) you actually use needs to be set.

# Groq
GROQ_API_KEY=
# Optional: override Groq's default model.
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (also works with any OpenAI-compatible hosted service)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: point at a different OpenAI-compatible base URL.
# OPENAI_BASE_URL=

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# Optional: cap reply length.
# ANTHROPIC_MAX_TOKENS=1024

# Local / self-hosted OpenAI-compatible server (Ollama, LM Studio, vLLM, ...).
# No key is required by default; the base URL points at Ollama out of the box.
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=llama3.1
# LOCAL_API_KEY=
