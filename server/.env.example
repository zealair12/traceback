# Traceback server configuration.
# Copy this file to ".env" and fill in real values. The ".env" file is private
# and is never committed.

# Port the API listens on.
PORT=4000

# PostgreSQL connection string for the conversation database.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/traceback

# Where the frontend is served from (used to allow browser requests).
CLIENT_ORIGIN=http://localhost:5173

# --- LLM provider selection -------------------------------------------------
# Which language-model backend answers messages by default. Traceback treats
# every backend as an interchangeable plugin; this picks the default one.
# Supported today: groq. (More providers are added as separate plugins.)
LLM_PROVIDER=groq

# --- Provider credentials ---------------------------------------------------
# Only the key for the provider(s) you actually use needs to be set.

# Groq
GROQ_API_KEY=
# Optional: override Groq's default model.
GROQ_MODEL=llama-3.3-70b-versatile
